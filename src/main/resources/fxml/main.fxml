<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.npopov.philharmonic.client.ui.main.MainController"
            styleClass="main-root">

    <!-- ── Top bar ─────────────────────────────────────────────────────── -->
    <top>
        <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="16">
            <HBox.margin><Insets bottom="0"/></HBox.margin>

            <Label text="🎼" styleClass="topbar-logo"/>
            <Label text="Филармония" styleClass="topbar-title"/>

            <!-- Spacer -->
            <Region HBox.hgrow="ALWAYS"/>

            <!-- Auth info (right side) -->
            <HBox alignment="CENTER" spacing="10" styleClass="auth-area">
                <Label fx:id="roleLabel" styleClass="role-badge"/>
                <Label fx:id="usernameLabel" styleClass="username-label"/>
                <Button text="Выйти"
                        onAction="#handleLogout"
                        styleClass="btn-logout"/>
            </HBox>
        </HBox>
    </top>

    <!-- ── Center: tab pane ────────────────────────────────────────────── -->
    <center>
        <TabPane fx:id="tabPane"
                 tabClosingPolicy="UNAVAILABLE"
                 styleClass="main-tabs">

            <Tab text="🎭 Мероприятия" fx:id="tabEvents">
                <StackPane fx:id="eventsPane"/>
            </Tab>

            <Tab text="🎤 Артисты" fx:id="tabArtists">
                <StackPane fx:id="artistsPane"/>
            </Tab>

            <Tab text="🏛 Площадки" fx:id="tabVenues">
                <StackPane fx:id="venuesPane"/>
            </Tab>

            <Tab text="👔 Импресарио" fx:id="tabImpresarios">
                <StackPane fx:id="impresariosPane"/>
            </Tab>

            <Tab text="🏢 Организаторы" fx:id="tabOrganizers">
                <StackPane fx:id="organizersPane"/>
            </Tab>

            <Tab text="🏆 Конкурсы" fx:id="tabCompetitions">
                <StackPane fx:id="competitionsPane"/>
            </Tab>

            <Tab text="🥇 Результаты" fx:id="tabResults">
                <StackPane fx:id="resultsPane"/>
            </Tab>

            <Tab text="🥇 Жанры" fx:id="tabGenres">
                <StackPane fx:id="genresPane"/>
            </Tab>

        </TabPane>
    </center>

    <!-- ── Bottom: status bar ──────────────────────────────────────────── -->
    <bottom>
        <HBox styleClass="status-bar" spacing="8" alignment="CENTER_LEFT">
            <Label fx:id="statusLabel" text="Готово" styleClass="status-label"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="serverLabel"
                   styleClass="server-label"/>
        </HBox>
    </bottom>

</BorderPane>
