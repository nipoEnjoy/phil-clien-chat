<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.npopov.philharmonic.client.ui.tabs.VenuesTabController"
      styleClass="tab-content-root"
      spacing="12">
    <HBox styleClass="toolbar-row" spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="🔍  Поиск..." styleClass="search-field"/>
        <FlowPane fx:id="filterBar" hgap="10" vgap="10" alignment="CENTER_LEFT" styleClass="filter-bar"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnRefresh" text="↻  Обновить" onAction="#refresh" styleClass="btn-secondary"/>
        <Button fx:id="btnCreate"  text="＋  Создать"  onAction="#handleCreate" styleClass="btn-action"/>
        <Button fx:id="btnEdit"    text="✎  Изменить"  onAction="#handleEdit" styleClass="btn-secondary"/>
        <Button fx:id="btnDelete"  text="✕  Удалить"   onAction="#handleDelete" styleClass="btn-danger"/>
    </HBox>
    <TableView fx:id="tableView" VBox.vgrow="ALWAYS" styleClass="table-view">
        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY_FLEX_LAST_COLUMN"/></columnResizePolicy>
    </TableView>
    <HBox alignment="CENTER_LEFT" spacing="10">
        <ProgressIndicator fx:id="loadingSpinner" prefWidth="16" prefHeight="16" visible="false"/>
        <Label fx:id="statusLabel" styleClass="status-label"/>
    </HBox>
</VBox>