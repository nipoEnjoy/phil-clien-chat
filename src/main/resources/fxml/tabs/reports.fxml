<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<VBox xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.npopov.philharmonic.client.ui.tabs.ReportsTabController"
      styleClass="tab-content-root"
      spacing="12">
    <HBox styleClass="toolbar-row" spacing="10" alignment="CENTER_LEFT">
        <ComboBox fx:id="reportTypeCombo" promptText="Тип отчёта" prefWidth="250"/>
        <DatePicker fx:id="startDatePicker" promptText="С даты"/>
        <DatePicker fx:id="endDatePicker" promptText="По дату"/>
        <Button fx:id="btnGenerate" text="Сформировать" styleClass="btn-action"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnRefresh" text="↻ Обновить" styleClass="btn-secondary"/>
    </HBox>
    <TableView fx:id="tableView" VBox.vgrow="ALWAYS" styleClass="table-view">
        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY_FLEX_LAST_COLUMN"/></columnResizePolicy>
    </TableView>
    <HBox alignment="CENTER_LEFT" spacing="10">
        <ProgressIndicator fx:id="loadingSpinner" prefWidth="16" prefHeight="16" visible="false"/>
        <Label fx:id="statusLabel" styleClass="status-label"/>
    </HBox>
</VBox>